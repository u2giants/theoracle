    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@oracle/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.5",
    "pg": "^8.13.1",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
