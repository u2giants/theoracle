# AI indexer ignore list — keep in sync with .cursorignore

# Dependencies
node_modules/

# Build output
apps/web/.next/
dist/
.turbo/
.vercel/

# Test / coverage artifacts
coverage/
.nyc_output/

# Cache
.cache/
*.tsbuildinfo

# Eval run outputs (per-timestamp; covered by packages/ai/evals/.gitignore but
# AI indexers don't read .gitignore — exclude explicitly).
packages/ai/evals/runs/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Lockfiles — giant, low signal; trust package.json
pnpm-lock.yaml

# Generated Drizzle migrations — source of truth is packages/db/src/schema.ts
# (Hand-written SQL in packages/db/migrations/sql/ IS read; only the auto-generated *.sql files at the top of /migrations are skipped.)
packages/db/migrations/0*.sql
packages/db/migrations/meta/

# Local env
.env.local
.env.*.local

# OS junk
.DS_Store
Thumbs.db
desktop.ini
