# AI indexer ignore list — keep in sync with .claudeignore

# Dependencies
node_modules/

# Build output
apps/web/.next/
dist/
.turbo/
.vercel/
.playwright-mcp/
.claude/

# Test / coverage artifacts
coverage/
.nyc_output/

# Cache
.cache/
*.tsbuildinfo

# Eval run outputs (per-timestamp)
packages/ai/evals/runs/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Lockfiles — giant, low signal; trust package.json
pnpm-lock.yaml

# Generated Drizzle migrations — source of truth is packages/db/src/schema.ts
packages/db/migrations/0*.sql
packages/db/migrations/meta/

# Local env
.env.local
.env.*.local

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Teams notification cert material (PRIVATE KEY — never commit)
oracle-teams-cert/
